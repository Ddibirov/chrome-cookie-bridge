{
  "manifest_version": 3,
  "name": "Chrome Cookie Bridge",
  "version": "2.0.0",
  "description": "Exports Chrome cookies to WSL via HTTP endpoint — no save dialogs.",
  "permissions": [
    "cookies",
    "alarms",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost:9487/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Cookie Bridge v2"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
